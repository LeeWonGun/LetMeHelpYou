# OpenAI / RAG variables currently used by the backend
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
USE_RAG=false
EMBED_MODEL=text-embedding-3-small
TOP_K=5
CHUNK_SIZE=800

# Present in the local configuration, but not currently read by the code
# OPENAI_TEMPERATURE=
# OPENAI_MAX_TOKENS=

# Variables used by Django settings
DJANGO_SECRET_KEY=
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

CORS_ALLOWED_ORIGINS=

# Local-only Flutter Web RAG demo (disabled by default)
LOCAL_DEMO_LOGIN=false
LOCAL_DEMO_USERNAME=portfolio_demo
DEMO_MEDIA_ROOT=
DEMO_FAISS_ROOT=
